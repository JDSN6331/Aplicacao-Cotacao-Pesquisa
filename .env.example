# ===========================================
# CONFIGURAÇÕES DA APLICAÇÃO COTAÇÃO-PESQUISA
# ===========================================
#
# INSTRUÇÕES:
# 1. Copie este arquivo para .env
# 2. Preencha os valores reais (NUNCA commit .env em git!)
# 3. Adicione .env ao .gitignore
# 4. Para produção, gere uma SECRET_KEY forte com:
#    python -c "import secrets; print(secrets.token_hex(32))"

# ===========================================
# SEGURANÇA (CRÍTICO!)
# ===========================================
# Gere uma chave secreta forte com: python -c "import secrets; print(secrets.token_hex(32))"
# OBRIGATÓRIO EM PRODUÇÃO!
SECRET_KEY=sua-chave-secreta-forte-aqui-32-caracteres-aleatorios

# ===========================================
# AMBIENTE
# ===========================================
# development, production, testing
FLASK_ENV=development
FLASK_DEBUG=false

# ===========================================
# BANCO DE DADOS
# ===========================================
# LOCAL (SQLite - padrão para desenvolvimento)
# DATABASE_URL=sqlite:///cotacoes.db
# USERS_DATABASE_URL=sqlite:///users.db

# PRODUÇÃO (PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/cotacoes_db
# USERS_DATABASE_URL=postgresql://user:password@localhost:5432/users_db

# ===========================================
# CONFIGURAÇÃO DO SERVIDOR
# ===========================================
PORT=5000
HOST=0.0.0.0

# ===========================================
# CONFIGURAÇÃO DE E-MAIL (SMTP)
# ===========================================
# Servidor SMTP
MAIL_SERVER=mail.cooxupe.com.br
MAIL_PORT=587
MAIL_USE_TLS=true

# Credenciais de e-mail (NUNCA commit em git!)
# Use credenciais de uma conta de app específica para segurança
MAIL_USERNAME=seu_email_app@cooxupe.com.br
MAIL_PASSWORD=sua_senha_de_app_segura_aqui

# Desativar envio de e-mails em desenvolvimento (true/false)
DESATIVAR_EMAILS=true

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=10

# ===========================================
# RATE LIMITING
# ===========================================
# URL de storage para rate limiting (memory:// para desenvolvimento)
RATELIMIT_STORAGE_URL=memory://

# ===========================================
# SEGURANÇA - HEADERS
# ===========================================
# Configurar em headers HTTP
SESSION_TIMEOUT=30  # minutos
LOGIN_RATE_LIMIT=5  # tentativas por minuto
